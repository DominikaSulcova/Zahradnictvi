---
// The shared page frame: <head> metadata, fonts, header illustration,
// sticky nav, content area, footer. Every page wraps itself in this layout.
import SkyScene from '../components/header/SkyScene.astro';
import MeadowNav from '../components/header/MeadowNav.astro';
import '../styles/tokens.css';
import '../styles/global.css';
import '../components/header/header.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zahradnictví Úsilné',
  description = 'Rodinné zahradnictví v Úsilném u Českých Budějovic — sadba zeleniny, balkónové květiny, bylinky a trvalky.',
} = Astro.props;

// Evaluated at build time; the site rebuilds on every content edit,
// so the year stays current.
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Fonts: Google Fonts serves the latin-ext subset automatically,
         which covers Czech diacritics (ěščřžýáíéůú). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=Caveat:wght@500&family=Manrope:wght@400;600;700&display=swap"
    />
  </head>
  <body>
    <!-- Clicking the illustration always returns home (there is no "Domů" nav item).
         Note: the nav strip stays OUTSIDE <header> — position:sticky only works
         while its parent is on screen, and the header scrolls away. -->
    <header>
      <a class="header-home-link" href="/" title="Zpět na úvod">
        <SkyScene />
      </a>
    </header>

    <MeadowNav />

    <main class="container">
      <slot />
    </main>

    <footer>© {year} Zahradnictví Úsilné</footer>
  </body>
</html>

<style>
  main {
    padding-block: 2.25rem 1rem;
    flex: 1;   /* main absorbs all leftover height, pushing the footer down */
  }

  footer {
    margin-top: 3rem;
    padding: 1.15rem 1rem;
    text-align: center;
    font-size: 0.8rem;
    background: var(--les);
    color: rgba(255, 255, 255, 0.85); /* spec §2.7: white at 85% on the deep green */
  }
</style>
