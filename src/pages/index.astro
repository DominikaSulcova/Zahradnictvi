---
// Home page: aktuality from the content collection, opening hours,
// contact card + map. Section order per the brief: Aktuality → Doba → Kontakt.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import AktualitaCard from '../components/AktualitaCard.astro';

// Only published entries, newest first.
const aktuality = (await getCollection('aktuality', ({ data }) => data.published))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <section id="aktuality">
    <SectionTitle plant="tulip" subtitle="co je u nás nového">Aktuality</SectionTitle>
    <div class="aktuality-list">
      {aktuality.map((entry) => <AktualitaCard entry={entry} />)}
    </div>
  </section>

  <section id="doba">
    <SectionTitle plant="daisy" subtitle="kdy k nám">Otevírací doba</SectionTitle>
    <div class="hours-card karta">
      <table>
        <tbody>
          <tr>
            <th scope="row">pondělí – pátek</th>
            <td>8:00 – 16:30</td>
          </tr>
          <tr>
            <th scope="row">sobota</th>
            <td>8:00 – 12:00</td>
          </tr>
          <tr>
            <th scope="row">neděle a svátky</th>
            <td class="closed">zavřeno</td>
          </tr>
        </tbody>
      </table>
      <p class="hours-note">Mimo otevírací dobu po telefonické domluvě.</p>
    </div>
  </section>

  <section id="kontakt">
    <SectionTitle plant="blossom" subtitle="kde nás najdete">Kontakt</SectionTitle>
    <div class="karta contact-card">
      <div class="contact-lines">
        <p class="contact-line">
          <!-- map-pin icon (spec §3.1: thin emerald strokes, round caps) -->
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21c-4-4.5-7-7.8-7-11a7 7 0 0 1 14 0c0 3.2-3 6.5-7 11z"></path>
            <circle cx="12" cy="10" r="2.6"></circle>
          </svg>
          <span>
            <strong>Úsilné 9, 370 10 Úsilné</strong><br />
            <span class="muted">u Českých Budějovic</span>
          </span>
        </p>
        <p class="contact-line">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M5 4h4l1.5 4-2 1.5a12 12 0 0 0 6 6l1.5-2 4 1.5v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"></path>
          </svg>
          <a href="tel:+420732264647">732 264 647</a>
        </p>
        <p class="contact-line">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="5.5" width="18" height="13" rx="2"></rect>
            <path d="M3.5 7l8.5 6 8.5-6"></path>
          </svg>
          <a href="mailto:marie.sulcova@volny.cz">marie.sulcova@volny.cz</a>
        </p>
        <p class="contact-line">
          <span class="fb-badge" aria-hidden="true">f</span>
          <a
            href="https://www.facebook.com/p/Zahradnictv%C3%AD-%C3%9Asiln%C3%A9-100059199107987/?locale=cs_CZ"
            rel="noopener"
          >Facebook</a>
        </p>
        <p class="contact-line">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
            <circle cx="12" cy="12" r="3.8"></circle>
            <circle class="dot" cx="17" cy="7" r="1.1"></circle>
          </svg>
          <a href="https://www.instagram.com/zahradnictviusilne/?hl=cs" rel="noopener">Instagram</a>
        </p>
      </div>
      <div class="map-wrap">
        <!-- Google Maps embed (keyless, free). `output=embed` renders the
             plain embeddable map; hl=cs keeps its UI in Czech. -->
        <iframe
          src="https://maps.google.com/maps?q=Zahradnictv%C3%AD+%C3%9Asiln%C3%A9,+%C3%9Asiln%C3%A9+9,+370+10+%C3%9Asiln%C3%A9&z=15&hl=cs&output=embed"
          title="Mapa — Zahradnictví Úsilné"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  section + section {
    margin-top: 3rem; /* owner-tuned up from the spec's ~32px rhythm */
  }

  .aktuality-list {
    display: grid;
    gap: 0.9rem; /* spec §1.3: ~14px between cards */
  }

  /* --- Otevírací doba --- */
  .hours-card {
    padding: 1.25rem;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.94rem;
  }

  /* Hairline row separators (spec §2.5: muted at 20%, none on the last row). */
  tr + tr {
    border-top: 1px solid color-mix(in srgb, var(--tlumena) 20%, transparent);
  }

  th {
    padding: 0.6rem 0;
    text-align: left;
    font-weight: 600;
  }

  td {
    padding: 0.6rem 0;
    text-align: right;
    font-weight: 700;
    font-variant-numeric: tabular-nums; /* digits share one width, so times align */
    color: var(--inkoust);
  }

  td.closed {
    color: var(--tlumena); /* spec §2.5: quiet, not alarming red */
    font-weight: 600;
  }

  .hours-note {
    margin: 0.9rem 0 0;
    font-size: 0.88rem;
    color: var(--tlumena);
  }

  /* --- Kontakt: one card with contact lines + map (spec §2.6) --- */
  .contact-card {
    padding: 1.25rem;
    display: grid;
    gap: 1rem;
  }

  /* Lines and map side by side once there's room (desktop). */
  @media (min-width: 44rem) {
    .contact-card {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
  }

  .contact-line {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 44px; /* comfortable touch target on phones (spec §4) */
    font-size: 0.94rem;
  }

  .muted {
    color: var(--tlumena);
    font-size: 0.85rem;
  }

  .contact-line a {
    color: var(--odkaz);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .icon {
    flex: none;
    width: 17px;
    height: 17px;
    fill: none;
    stroke: var(--novinka);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .icon .dot {
    fill: var(--novinka);
    stroke: none;
  }

  .fb-badge {
    flex: none;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: var(--novinka);
    color: #fff;
    font-family: var(--pismo-nadpisy);
    font-weight: 700;
    font-size: 11px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .map-wrap {
    /* Nested surface inside the card: smaller radius than the card itself. */
    border-radius: var(--radius-vnoreny);
    overflow: hidden;
    min-height: 10rem;
    display: grid;
  }

  iframe {
    width: 100%;
    height: 100%;
    min-height: 10rem;
    border: 0;
  }
</style>
