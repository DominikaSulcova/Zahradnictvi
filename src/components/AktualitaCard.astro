---
// One news card: accent bar on top, style pill + date row, title, short text,
// and (optionally) photos in a right-hand column — a CSS scroll-snap strip
// showing one photo at a time. The entry's `style` field (novinka / vyprodej /
// sezonni) is the only appearance choice the editor gets (The Three Styles Rule).
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  entry: CollectionEntry<'aktuality'>;
}
const { entry } = Astro.props;
const { Content } = await render(entry);
const photos = entry.data.photos;

const LABELS = {
  novinka: 'Novinka',
  vyprodej: 'Výprodej',
  sezonni: 'Sezónní',
};

// "1. 7. 2026" — the Czech short date format, generated from the real Date
// so entries never need a hand-formatted date string.
const datum = new Intl.DateTimeFormat('cs-CZ', {
  day: 'numeric',
  month: 'numeric',
  year: 'numeric',
}).format(entry.data.date);
---

<article class:list={['karta', `aktualita--${entry.data.style}`]}>
  <div class="accent-bar"></div>
  <div class:list={['card-body', { 'has-photos': photos.length > 0 }]}>
    <div class="card-text">
      <div class="meta-row">
        <span class="pill">{LABELS[entry.data.style]}</span>
        {/* Without photos the date stays up here; with photos it moves into
            the photo column (owner's layout, 2026-07-05). */}
        {photos.length === 0 && (
          <time datetime={entry.data.date.toISOString().slice(0, 10)}>{datum}</time>
        )}
      </div>
      <h3>{entry.data.title}</h3>
      <div class="text">
        <Content />
      </div>
    </div>

    {photos.length > 0 && (
      <div class="photo-box">
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>{datum}</time>
        <!-- The polaroid frame wraps the scroll strip: photos slide INSIDE the
             frame, the white border and shadow stay put.
             width = 2× the displayed column width, for crisp high-DPI screens;
             Astro generates the resized, compressed file at build time.
             alt="" until entries carry captions (CMS milestone). -->
        <div class="polaroid">
          <div class="photo-track">
            {photos.map((photo) => <Image class="photo" src={photo} width={640} alt="" />)}
          </div>
          {photos.length > 1 && (
            <>
              <button class="arrow arrow-prev" type="button" aria-label="Předchozí fotka">‹</button>
              <button class="arrow arrow-next" type="button" aria-label="Další fotka">›</button>
            </>
          )}
        </div>
      </div>
    )}
  </div>
</article>

<style>
  /* Each style variant only sets --akcent; everything below reads it.
     Adding a fourth style one day = one token + one line here. */
  .aktualita--novinka {
    --akcent: var(--novinka);
  }
  .aktualita--vyprodej {
    --akcent: var(--vyprodej);
  }
  .aktualita--sezonni {
    --akcent: var(--sezonni);
  }

  article {
    /* Clip the accent bar to the card's rounded corners. */
    overflow: hidden;
  }

  .accent-bar {
    height: 6px;
    background: var(--akcent);
  }

  .card-body {
    padding: 1.25rem 1.25rem 2.5rem;
  }

  /* With photos, the body splits into text | photo column (owner: photo
     column ≈ 45% of the card, both columns top-aligned). */
  .card-body.has-photos {
    display: grid;
    grid-template-columns: 1fr 45%;
    gap: 1rem;
    align-items: start;
  }

  /* Photo column: date on top (right corner of the card), photo below. */
  .photo-box {
    display: grid;
    gap: 0.4rem;
  }

  .photo-box time {
    text-align: right;
  }

  /* Polaroid frame: thin white border, classic thick bottom, soft shadow.
     The white frame reads against the white card thanks to the shadow. */
  .polaroid {
    position: relative; /* anchor for the absolutely-positioned arrows */
    margin: 0.4rem 1rem 0; /* owner-tuned breathing room in the photo column */
    padding: 0.45rem 0.45rem 1.5rem; /* thick bottom = the polaroid signature */
    background: var(--karta);
    box-shadow: 0 2px 10px rgba(45, 60, 50, 0.25);
  }

  /* Prev/next arrows, floating over the photo's side edges. */
  .arrow {
    position: absolute;
    /* Vertical center of the PHOTO, not the frame (the bottom lip is thicker
       than the top border, so the frame's midpoint sits a bit too low). */
    top: calc(50% - 0.5rem);
    transform: translateY(-50%);
    width: 1.7rem;
    height: 1.7rem;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    color: var(--les);
    font-size: 1.15rem;
    line-height: 1;
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(45, 60, 50, 0.3);
  }

  .arrow:hover {
    background: var(--karta);
  }

  .arrow-prev {
    left: 0.75rem;
  }

  .arrow-next {
    right: 0.75rem;
  }

  /* The photo strip: a horizontal scroll-snap carousel, no JS needed.
     Each photo fills the column, so scrolling always lands on one photo. */
  .photo-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    /* Hide the scrollbar — swiping and (soon) arrows are the controls. */
    scrollbar-width: none;
  }

  .photo-track::-webkit-scrollbar {
    display: none;
  }

  .photo {
    flex: none;
    width: 100%;
    height: 14rem; /* ← precise photo height, owner-tunable */
    object-fit: cover; /* fill the box by cropping, never by squashing */
    scroll-snap-align: start;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: -0.3rem;   /* ← add this: negative margin pulls the row up */
  }

  .pill {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    /* Tint the accent for the pill: light wash behind, darkened ink on top.
       color-mix keeps both derived from the one --akcent token, so the pill
       always matches its accent bar (and stays WCAG-readable). Spec §1.1:
       pill background = accent at ~13% over card white, mixed in oklab. */
    background: color-mix(in oklab, var(--akcent) 13%, white);
    color: color-mix(in srgb, var(--akcent) 60%, var(--inkoust));
  }

  time {
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--tlumena);
  }

  h3 {
    margin: 0.8rem 0 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--inkoust); /* card titles are ink, not forest green (spec §1.2) */
  }

  .text {
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--tlumena); /* card body copy is the muted tone (spec §1.2) */
  }

  .text :global(p) {
    margin: 0.35rem 0 0;
  }
</style>

<script>
  // The site's first client-side JavaScript: unlike the code at the top of
  // this file (which runs at build time), this runs in the visitor's browser.
  // Astro includes it ONCE per page, so we wire up every photo box we find.

  // People who prefer reduced motion get an instant jump instead of a glide.
  const behavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ? 'auto'
    : ('smooth' as ScrollBehavior);

  document.querySelectorAll('.photo-box').forEach((box) => {
    const track = box.querySelector('.photo-track');
    if (!(track instanceof HTMLElement)) return;

    // One step = the strip's visible width = exactly one photo;
    // the scroll-snap CSS then settles the strip onto the nearest photo.
    // The carousel loops: past the last photo it returns to the first,
    // and before the first it jumps to the last. (The 2px tolerance is
    // because scroll positions can be fractions of a pixel.)
    const step = (direction: number) => {
      const max = track.scrollWidth - track.clientWidth;
      if (direction > 0 && track.scrollLeft >= max - 2) {
        track.scrollTo({ left: 0, behavior });
      } else if (direction < 0 && track.scrollLeft <= 2) {
        track.scrollTo({ left: max, behavior });
      } else {
        track.scrollBy({ left: direction * track.clientWidth, behavior });
      }
    };

    box.querySelector('.arrow-prev')?.addEventListener('click', () => step(-1));
    box.querySelector('.arrow-next')?.addEventListener('click', () => step(1));
  });
</script>
